# Core runtime
COGNITIVEOS_HOME=~/.cognitiveos
# COGNITIVEOS_DB_PATH=
# COGNITIVEOS_MEMORY_OUTPUT_PATH=
COGNITIVEOS_BOOTSTRAP_DIR=./.cognitiveos/bootstrap
COGNITIVEOS_DEFAULT_ACTOR=agent
COGNITIVEOS_SIMILARITY_THRESHOLD=0.92
COGNITIVEOS_HYBRID_SEMANTIC_WEIGHT=0.65
COGNITIVEOS_HYBRID_KEYWORD_WEIGHT=0.35
COGNITIVEOS_SEARCH_CANDIDATE_CAP=20
COGNITIVEOS_SEARCH_GOVERNANCE_INTERVAL_SECONDS=300
COGNITIVEOS_SEARCH_ASYNC_ACCESS_LOGGING=true
COGNITIVEOS_SEMANTIC_NEIGHBOR_K=8
COGNITIVEOS_DREAM_EVENT_THRESHOLD=10
COGNITIVEOS_DREAM_MAX_AGE_HOURS=24
COGNITIVEOS_DREAM_AGE_MIN_EVENT_COUNT=5

# Document ingestion and chunking
COGNITIVEOS_LONG_DOCUMENT_TOKEN_THRESHOLD=1200
COGNITIVEOS_CHUNK_TARGET_TOKENS=900
COGNITIVEOS_CHUNK_OVERLAP_TOKENS=120
COGNITIVEOS_MAX_MAIN_DOCUMENT_CHARS=6000
COGNITIVEOS_MAX_NODE_CONTENT_CHARS=12000

# Relationship governance
COGNITIVEOS_RELATIONSHIP_WEAK_AFTER_HOURS=72
COGNITIVEOS_RELATIONSHIP_STALE_AFTER_HOURS=168
COGNITIVEOS_RELATIONSHIP_WEAK_STRENGTH_THRESHOLD=0.85
COGNITIVEOS_RELATIONSHIP_STALE_STRENGTH_THRESHOLD=0.35
COGNITIVEOS_RELATIONSHIP_WEAK_DECAY_DELTA=0.2
COGNITIVEOS_RELATIONSHIP_STALE_DECAY_DELTA=0.35
COGNITIVEOS_RELATIONSHIP_MANUAL_REINFORCEMENT_DELTA=0.5
COGNITIVEOS_RELATIONSHIP_RECALL_REINFORCEMENT_DELTA=0.1
COGNITIVEOS_RELATIONSHIP_DREAM_REINFORCEMENT_DELTA=0.2

# MCP server
COGNITIVEOS_SERVER_NAME=CognitiveOS
COGNITIVEOS_SERVER_HOST=127.0.0.1
COGNITIVEOS_SERVER_PORT=8000
COGNITIVEOS_SERVER_PATH=/mcp
COGNITIVEOS_SERVER_PROFILE=host-core

# Embedding provider
# Supported types: ollama, openai, gemini, local_huggingface
# Anthropic is chat-only in the current implementation.
COGNITIVEOS_EMBEDDING_PROVIDER_TYPE=
COGNITIVEOS_EMBEDDING_MODEL_NAME=
COGNITIVEOS_EMBEDDING_BASE_URL=
COGNITIVEOS_EMBEDDING_API_KEY=

# Chat provider
# Supported types: ollama, openai, anthropic, gemini, local_huggingface
COGNITIVEOS_CHAT_PROVIDER_TYPE=
COGNITIVEOS_CHAT_MODEL_NAME=
COGNITIVEOS_CHAT_BASE_URL=
COGNITIVEOS_CHAT_API_KEY=

# Example: Ollama
# COGNITIVEOS_EMBEDDING_PROVIDER_TYPE=ollama
# COGNITIVEOS_EMBEDDING_MODEL_NAME=nomic-embed-text
# COGNITIVEOS_EMBEDDING_BASE_URL=http://localhost:11434/api
# COGNITIVEOS_CHAT_PROVIDER_TYPE=ollama
# COGNITIVEOS_CHAT_MODEL_NAME=gemma3
# COGNITIVEOS_CHAT_BASE_URL=http://localhost:11434/api

# Example: OpenAI
# COGNITIVEOS_EMBEDDING_PROVIDER_TYPE=openai
# COGNITIVEOS_EMBEDDING_MODEL_NAME=text-embedding-3-small
# COGNITIVEOS_EMBEDDING_API_KEY=
# COGNITIVEOS_CHAT_PROVIDER_TYPE=openai
# COGNITIVEOS_CHAT_MODEL_NAME=gpt-5-mini
# COGNITIVEOS_CHAT_API_KEY=

# Example: Anthropic chat only
# COGNITIVEOS_CHAT_PROVIDER_TYPE=anthropic
# COGNITIVEOS_CHAT_MODEL_NAME=claude-3-7-sonnet-latest
# COGNITIVEOS_CHAT_API_KEY=

# Example: Gemini
# COGNITIVEOS_EMBEDDING_PROVIDER_TYPE=gemini
# COGNITIVEOS_EMBEDDING_MODEL_NAME=text-embedding-004
# COGNITIVEOS_EMBEDDING_API_KEY=
# COGNITIVEOS_CHAT_PROVIDER_TYPE=gemini
# COGNITIVEOS_CHAT_MODEL_NAME=gemini-2.5-flash
# COGNITIVEOS_CHAT_API_KEY=

# Example: Local Hugging Face
# Requires: pip install "cognitiveos[local-hf]"
# COGNITIVEOS_EMBEDDING_PROVIDER_TYPE=local_huggingface
# COGNITIVEOS_EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# COGNITIVEOS_CHAT_PROVIDER_TYPE=local_huggingface
# COGNITIVEOS_CHAT_MODEL_NAME=google/flan-t5-base
